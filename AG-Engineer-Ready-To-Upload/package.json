{
  "name": "antigravity-engineer",
  "displayName": "Antigravity Engineer",
  "description": "Monitor context window usage, model quotas, and token consumption for Google Antigravity IDE",
  "version": "0.3.12",
  "publisher": "jetnet",
  "repository": {
    "type": "git",
    "url": "https://github.com/jetnet/ag-engineer.git"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "antigravity",
    "context",
    "tokens",
    "quota",
    "monitor"
  ],
  "icon": "resources/icon.png",
  "activationEvents": [
    "onStartupFinished",
    "onView:antigravityEngineer.dashboard",
    "onCommand:antigravityEngineer.openDashboard"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "antigravityEngineer.openDashboard",
        "title": "Antigravity Engineer: Open Dashboard"
      },
      {
        "command": "antigravityEngineer.refreshNow",
        "title": "Antigravity Engineer: Refresh Now"
      },
      {
        "command": "antigravityEngineer.showDiagnostics",
        "title": "Antigravity Engineer: Show Diagnostics"
      },
      {
        "command": "antigravityEngineer.resetState",
        "title": "Antigravity Engineer: Reset State"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "antigravity-engineer",
          "title": "AG Engineer",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "antigravity-engineer": [
        {
          "type": "webview",
          "id": "antigravityEngineer.dashboard",
          "name": "Dashboard"
        }
      ]
    },
    "configuration": {
      "title": "Antigravity Engineer",
      "properties": {
        "antigravityEngineer.pollingInterval": {
          "type": "number",
          "default": 30,
          "minimum": 5,
          "maximum": 300,
          "description": "Polling interval in seconds for quota/context updates"
        },
        "antigravityEngineer.lowQuotaThreshold": {
          "type": "number",
          "default": 30,
          "minimum": 5,
          "maximum": 90,
          "description": "Show warning when model quota drops below this percentage"
        },
        "antigravityEngineer.criticalQuotaThreshold": {
          "type": "number",
          "default": 10,
          "minimum": 1,
          "maximum": 50,
          "description": "Show critical warning when model quota drops below this percentage"
        },
        "antigravityEngineer.contextLimitOverrides": {
          "type": "object",
          "default": {},
          "description": "JSON object mapping internal model identifiers (e.g. 'claude-sonnet') to custom token limits"
        },
        "antigravityEngineer.serverHost": {
          "type": "string",
          "default": "127.0.0.1",
          "description": "Language server host (almost always 127.0.0.1)"
        },
        "antigravityEngineer.debugMode": {
          "type": "boolean",
          "default": false,
          "description": "Enable verbose debug logging"
        },
        "antigravityEngineer.allowUnknownWorkspaceFallback": {
          "type": "boolean",
          "default": false,
          "description": "Allow conversations without workspace metadata to be auto-selected when no workspace-matched conversation is found. When false (default), only conversations explicitly associated with the current workspace are shown."
        },
        "antigravityEngineer.loadTrajectoryTtlSeconds": {
          "type": "number",
          "default": 120,
          "minimum": 30,
          "maximum": 600,
          "description": "How long (seconds) to suppress repeated LoadTrajectory recovery calls for the same conversation before allowing a retry. Lower values re-arm faster after a conversation goes cold; higher values reduce redundant server calls."
        },
        "antigravityEngineer.statusBar.showContextWindow": {
          "type": "boolean",
          "default": true,
          "description": "Show context window usage (model, tokens) in the status bar"
        },
        "antigravityEngineer.statusBar.models": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "Pro",
            "Flash",
            "Sonnet",
            "Opus",
            "GPT"
          ],
          "markdownDescription": "Which models to show in the status bar quota dots. Use short names: `Opus`, `Sonnet`, `Pro`, `Flash`, `GPT`. Empty = show all."
        },
        "antigravityEngineer.statusBar.showCredits": {
          "type": "boolean",
          "default": true,
          "description": "Show AI credits in the status bar"
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "lint": "eslint src/ --ext .ts",
    "test": "vitest run",
    "package": "npm run build && npx -y @vscode/vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "esbuild": "^0.21.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0"
  }
}
